<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>dns-monitoring</Name>
  <Repository>freemen810/dns-monitoring:latest</Repository>
  <Registry>https://hub.docker.com/r/freemen810</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/freemen810/dns-monitoring</Support>
  <Project>https://github.com/freemen810/dns-monitoring</Project>
  <Overview>DNS Monitoring WebApp - Self-hosted DNS query monitoring and analytics web application with React frontend and Express backend</Overview>
  <Category>Network</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/freemen810/dns-monitoring/main/dns-monitoring-unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/freemen810/dns-monitoring/main/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <RunCmd>docker-compose -f docker-compose.yml up -d</RunCmd>
  <StopCmd>docker-compose down</StopCmd>
  <RemoveCmd>docker-compose down -v</RemoveCmd>
  <ReopenCommand/>
  <RestartPolicy>unless-stopped</RestartPolicy>
  <Environment>
    <Variable Name="NODE_ENV" Value="production" Description="Node environment"/>
    <Variable Name="PORT" Value="3000" Description="Backend API port"/>
    <Variable Name="CORS_ORIGIN" Value="*" Description="CORS origin for API requests"/>
    <Variable Name="DATABASE_PATH" Value="/app/data/dns-monitoring.db" Description="SQLite database path"/>
    <Variable Name="DEFAULT_DNS_SERVER" Value="1.1.1.1" Description="Default DNS server (Cloudflare)"/>
    <Variable Name="QUERY_TIMEOUT_MS" Value="5000" Description="DNS query timeout in milliseconds"/>
    <Variable Name="LOG_LEVEL" Value="info" Description="Application log level"/>
    <Variable Name="QUERY_RETENTION_DAYS" Value="30" Description="Days to retain query history"/>
  </Environment>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>3000</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/dns-monitoring/data</HostDir>
      <ContainerDir>/app/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Description>
DNS Monitoring is a self-hosted DNS query monitoring and analytics web application.

Features:
- Real-time DNS query monitoring and logging
- Query analytics and reporting
- Web-based dashboard with React frontend
- REST API for programmatic access
- SQLite database for persistent storage
- CORS support for cross-origin requests
- Configurable DNS servers and query timeouts
- Query retention policies

Default Access:
- URL: http://[IP]:3000
- All services available immediately after container starts

Data Persistence:
- Database stored in /mnt/user/appdata/dns-monitoring/data

GitHub: https://github.com/freemen810/dns-monitoring
  </Description>
  <Labels/>
  <Config Name="WebUI Port" Target="3000" Default="3000" Mode="tcp" Description="Port for web interface" Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Data Volume" Target="/app/data" Default="/mnt/user/appdata/dns-monitoring/data" Mode="rw" Description="Path for DNS monitoring database" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="NODE_ENV" Target="NODE_ENV" Default="production" Mode="" Description="Node environment (development/production)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="CORS_ORIGIN" Target="CORS_ORIGIN" Default="*" Mode="" Description="CORS origin for API requests" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="DEFAULT_DNS_SERVER" Target="DEFAULT_DNS_SERVER" Default="1.1.1.1" Mode="" Description="Default DNS server address" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="QUERY_TIMEOUT_MS" Target="QUERY_TIMEOUT_MS" Default="5000" Mode="" Description="DNS query timeout (milliseconds)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="LOG_LEVEL" Target="LOG_LEVEL" Default="info" Mode="" Description="Log level (debug/info/warn/error)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="QUERY_RETENTION_DAYS" Target="QUERY_RETENTION_DAYS" Default="30" Mode="" Description="Days to keep query history" Type="Variable" Display="always" Required="false" Mask="false"/>
</Container>
