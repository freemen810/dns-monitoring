<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>dns-monitoring</Name>
  <Repository>freemen810/dns-monitoring:latest</Repository>
  <Registry>https://hub.docker.com</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/freemen810/dns-monitoring</Support>
  <Project>https://github.com/freemen810/dns-monitoring</Project>
  <Overview>DNS Monitoring - Self-hosted DNS query monitoring with React frontend and Express backend</Overview>
  <Category>Network:DNS</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/freemen810/dns-monitoring/main/unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/freemen810/dns-monitoring/main/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <RunCmd/>
  <StopCmd/>
  <RemoveCmd/>
  <RestartPolicy>unless-stopped</RestartPolicy>
  <Environment>
    <Variable Name="TZ" Value="Asia/Singapore" Description="Timezone"/>
    <Variable Name="NODE_ENV" Value="production" Description="Node environment"/>
    <Variable Name="CORS_ORIGIN" Value="*" Description="CORS origin"/>
    <Variable Name="DEFAULT_DNS_SERVER" Value="1.1.1.1" Description="Default DNS server"/>
    <Variable Name="QUERY_TIMEOUT_MS" Value="5000" Description="Query timeout ms"/>
    <Variable Name="LOG_LEVEL" Value="info" Description="Log level"/>
    <Variable Name="QUERY_RETENTION_DAYS" Value="30" Description="Retention days"/>
  </Environment>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>3000</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/dns-monitoring</HostDir>
      <ContainerDir>/app/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Description>
DNS Monitoring Web Application

Real-time DNS query monitoring and analytics dashboard.

Features:
- Real-time DNS query monitoring
- React-based web dashboard
- REST API backend
- SQLite database
- Query analytics

Access: http://[IP]:3000

GitHub: https://github.com/freemen810/dns-monitoring
  </Description>
  <Config Name="Host Port" Target="3000" Default="3000" Mode="tcp" Description="Web UI Port" Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Data Path" Target="/app/data" Default="/mnt/user/appdata/dns-monitoring" Mode="rw" Description="Data Volume Path" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="Asia/Singapore" Mode="" Description="Container Timezone" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="DNS Server" Target="DEFAULT_DNS_SERVER" Default="1.1.1.1" Mode="" Description="Default DNS Server" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Log Level" Target="LOG_LEVEL" Default="info" Mode="" Description="Log Level" Type="Variable" Display="always" Required="false" Mask="false"/>
</Container>
