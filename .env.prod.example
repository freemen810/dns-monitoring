# DNS Monitoring - Production Environment Configuration
# Copy to .env.prod and customize for your deployment

################################################################################
# NODE.JS & SERVER
################################################################################

# Node.js environment
NODE_ENV=production

# Backend API port (inside container)
PORT=3000

################################################################################
# FRONTEND CONFIGURATION
################################################################################

# Frontend API URL (what the browser uses to reach the backend)
# Examples:
#   http://192.168.1.100/api           (IP with nginx proxy)
#   http://example.com/api             (domain with nginx proxy)
#   http://example.com:3000            (domain with custom port)
#   https://example.com/api            (HTTPS with nginx proxy)
VITE_API_URL=http://localhost/api

################################################################################
# BACKEND CONFIGURATION
################################################################################

# CORS origin (what origin frontend can make requests from)
# Use * for permissive (Docker environment), or specific domain in production
# Examples:
#   *                              (Allow any origin)
#   http://example.com             (Specific domain)
#   https://example.com            (HTTPS domain)
CORS_ORIGIN=*

# Default DNS server to use if not specified per monitor
DEFAULT_DNS_SERVER=1.1.1.1

# DNS query timeout in milliseconds
QUERY_TIMEOUT_MS=5000

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Query result retention (in days) - older records automatically deleted
QUERY_RETENTION_DAYS=30

################################################################################
# SYSTEM CONFIGURATION
################################################################################

# Timezone for timestamps and scheduling
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Singapore

################################################################################
# DOCKER COMPOSE VARIABLES
################################################################################

# Prefix for container names (useful when running multiple instances)
CONTAINER_PREFIX=dns-monitoring

# External HTTP port (host machine)
EXTERNAL_PORT=80

# External HTTPS port (host machine) - requires SSL certificates
EXTERNAL_HTTPS_PORT=443

################################################################################
# OPTIONAL: DEPLOYMENT METADATA
################################################################################

# These are informational and set by deploy.sh automatically
# DEPLOYED_AT=2026-03-21 15:30:00 UTC
# DEPLOYED_TO=http://example.com
